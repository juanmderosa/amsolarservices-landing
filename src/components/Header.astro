---
import menu from "../assets/svg/menu.svg?raw";
import close from "../assets/svg/close.svg?raw";
import Logo from "../assets/Logo.png";
import Image from "astro/components/Image.astro";
---

<header class="absolute top-0 w-full z-50 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24 lg:h-32">
      <div class="flex items-center">
        <a
          href="/"
          class="flex items-center gap-3">
          <Image
            class="h-16 lg:h-24 w-auto filter brightness-0 invert"
            src={Logo}
            alt="AM Solar Services"
          />
        </a>
      </div>

      <nav class="hidden md:flex space-x-8">
        <a
          href="#"
          class="hover:text-accent transition-colors font-medium"
          >Home</a
        >
        <a
          href="#services"
          class="hover:text-accent transition-colors font-medium"
          >Services</a
        >
        <a
          href="#about"
          class="hover:text-accent transition-colors font-medium"
          >About</a
        >
        <a
          href="#contact"
          class="hover:text-accent transition-colors font-medium"
          >Contact</a
        >
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          type="button"
          id="mobile-toggle"
          class="relative z-50 text-white hover:text-accent focus:outline-none transition-colors"
          aria-label="Toggle navigation menu">
          <!-- Icon Menu (Hamburger) -->
          <span class="block icon-menu">
            <Fragment set:html={menu} />
          </span>
          <!-- Icon Close (X) -->
          <span class="hidden icon-close">
            <Fragment set:html={close} />
          </span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  /* Button Icon Toggling */
  #mobile-toggle.is-open .icon-menu {
    display: none;
  }
  #mobile-toggle.is-open .icon-close {
    display: block;
  }
</style>

<script>
  const toggleBtn = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobileMenu');

  toggleBtn?.addEventListener('click', () => {
    const isOpen = toggleBtn.classList.toggle('is-open');
    
    if (mobileMenu) {
      if (isOpen) {
        mobileMenu.classList.remove('hidden');
        mobileMenu.classList.add('flex');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        document.body.style.overflow = '';
      }
    }
  });

  // Listener global para cerrar si se hace click en algún link del nav mobile
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggleBtn?.classList.remove('is-open');
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      document.body.style.overflow = '';
    });
  });
</script>
