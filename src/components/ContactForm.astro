---
import FormInput from "@components/FormInput.astro";
import TextArea from "@components/TextArea.astro";
---

<form
  id="contactForm"
  method="POST"
  action="/api/contact"
  novalidate
  class="flex flex-col gap-4 grow">
  <FormInput
    name="name"
    label="Name"
    placeholder="Your full name"
  />
  <FormInput
    name="company"
    label="Company"
    placeholder="Your company"
  />
  <FormInput
    name="email"
    label="Email"
    type="email"
    placeholder="you@example.com"
  />
  <TextArea
    label="message"
    name="message"
    placeholder="How can we help you?"
  />
  <!-- Submit -->
  <button
    type="submit"
    id="submitBtn"
    class="mt-4 bg-accent text-white font-semibold py-3 px-6 rounded-md hover:bg-white hover:text-primary transition-colors duration-300 text-sm tracking-wide cursor-pointer">
    Start a Conversation
  </button>

  <!-- Success / Error feedback -->
  <div
    id="formSuccess"
    class="hidden text-green-300 text-sm text-center mt-2 p-2 border border-green-400/40 rounded">
    ✅ Message sent successfully! We'll be in touch soon.
  </div>
  <div
    id="formError"
    class="hidden text-red-300 text-sm text-center mt-2 p-2 border border-red-400/40 rounded">
  </div>
</form>

<script>
  import "../utils/sendEmail.js";
</script>
