---
import engineering from "../assets/svg/engineering.svg?raw";
import crews from "../assets/svg/crews.svg?raw";
import integration from "../assets/svg/integration.svg?raw";

const reasons = [
  {
    icon: engineering,
    title: "Engineering-Led Execution",
  },
  {
    icon: crews,
    title: "Specialized Field Crews",
  },
  {
    icon: integration,
    title: "EPC & O&M Integration",
  },
];
---

<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 bg-[#eef1f8] p-8">
  {
    reasons.map((reason) => (
      <div class="flex flex-col items-center text-center group">
        <div
          class="text-primary mb-3 group-hover:scale-110 transition-transform duration-300"
          set:html={reason.icon}
        />
        <p class="font-semibold text-primary text-base">{reason.title}</p>
      </div>
    ))
  }
</div>
