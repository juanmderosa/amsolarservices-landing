<section class="relative bg-background">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-20 md:-mt-32 z-20">
    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <!-- The Problem -->
        <div class="p-10 md:p-16 bg-gray-50/50">
          <h2 class="text-3xl lg:text-4xl font-bold mb-8 text-primary">The Problem</h2>
          <ul class="space-y-5 text-base md:text-lg font-medium text-gray-700">
            <li class="flex items-start">
              <span class="text-secondary mr-4 text-xl">•</span>
              <span>Tracker misalignment reduces energy output</span>
            </li>
            <li class="flex items-start">
              <span class="text-secondary mr-4 text-xl">•</span>
              <span>Mechanical issues create delays and rework</span>
            </li>
            <li class="flex items-start">
              <span class="text-secondary mr-4 text-xl">•</span>
              <span>Limited field diagnostics affect performance</span>
            </li>
          </ul>
        </div>

        <!-- The Solution -->
        <div class="p-10 md:p-16">
          <h2 class="text-3xl lg:text-4xl font-bold mb-8 text-primary">The Solution</h2>
          <ul class="space-y-5 text-base md:text-lg font-medium text-gray-700">
            <li class="flex items-start">
              <span class="text-primary-light mr-4 text-xl">•</span>
              <span>Specialized field services focused on tracker systems</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-light mr-4 text-xl">•</span>
              <span>Rapid deployment field crews</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-light mr-4 text-xl">•</span>
              <span>Engineering-driven field execution</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
