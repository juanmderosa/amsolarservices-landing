---
import { Image } from "astro:assets";
import heroImg from "@assets/problemsolution.jpg";
---

<section
  id="hero"
  class="relative bg-dark pt-24 pb-48 lg:pt-36 lg:pb-64 overflow-hidden min-h-[500px] flex items-center justify-center">
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Solar Tracker System at Sunset"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-linear-to-b from-[rgba(13,25,48,0.6)] to-[rgba(0,0,0,0.4)]">
    </div>
  </div>

  <div
    class="relative max-w-7xl mx-auto px-4 pt-16 sm:px-6 lg:px-8 text-center text-white z-10">
    <h1 class="text-3xl md:text-3xl lg:text-4xl font-bold leading-tight mb-6">
      Reducing Risk. Optimizing Solar Tracker Performance.
    </h1>
    <p
      class="text-lg md:text-xl lg:text-2xl font-medium mb-4 max-w-4xl mx-auto">
      Specialized field services for EPCs, asset owners, and O&M providers<br
        class="hidden md:block"
      /> in utility-scale solar projects.
    </p>
    <p
      class="text-base md:text-lg font-normal mb-8 max-w-3xl mx-auto text-gray-200">
      Multi-state project support across the United States.
    </p>
  </div>
</section>
