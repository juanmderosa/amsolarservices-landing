---
interface Props {
  name: string;
  label: string;
  placeholder?: string;
  required?: boolean;
}

const { name, label, placeholder = "", required = true } = Astro.props;
---

<div class="flex flex-col gap-1">
  <label
    for={name}
    class="text-xs text-gray-300 uppercase tracking-wider"
    >{label}</label
  >
  <textarea
    id={name}
    name={name}
    required={required}
    rows="3"
    placeholder={placeholder}
    class="bg-transparent border-b border-white/40 focus:border-white text-white placeholder-white/40 py-2 text-sm outline-none transition-colors duration-200 resize-none"
  ></textarea>
  <span
    class="text-red-300 text-xs hidden"
    data-error={name}
  ></span>
</div>
